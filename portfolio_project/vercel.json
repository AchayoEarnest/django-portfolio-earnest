{
  "buildCommand": "pip install -r requirements.txt && python manage.py collectstatic --noinput && python manage.py migrate",
  "outputDirectory": "staticfiles",
  "env": {
    "PYTHONUNBUFFERED": "1"
  },
  "functions": {
    "portfolio_project/wsgi.py": {
      "memory": 3008,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "portfolio_project/wsgi.py"
    }
  ]
}