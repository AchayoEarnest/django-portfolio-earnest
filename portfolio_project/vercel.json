{
  "buildCommand": "pip install -r requirements.txt && python manage.py collectstatic --noinput",
  "outputDirectory": ".",
  "env": {
    "PYTHONUNBUFFERED": "1",
    "DEBUG": "False"
  },
  "functions": {
    "portfolio_project/wsgi.py": {
      "memory": 3008,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "/static/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/portfolio_project/wsgi.py"
    }
  ]
}
